# ──────────────────────────────────────────────────────────────────────
# Reachy Mini Agent — environment variables
# Copy to `.env` and adjust. run_robot.sh sources this automatically.
# ──────────────────────────────────────────────────────────────────────

# ── Reachy connection ─────────────────────────────────────────────────
# Host/IP of the Reachy Mini daemon. Use mDNS name by default; set to a
# specific IP (LAN or Tailscale) for remote control.
REACHY_HOST=reachy-mini.local

# ── LLM (brain) ───────────────────────────────────────────────────────
# Options: ollama | litellm | claude-sdk | claude-cli
LLM_MODE=ollama

# Ollama (local)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3.6:35b-a3b
OLLAMA_THINK=0                 # 1 = chain-of-thought mode (slower)

# LLM runtime behaviour
LLM_STREAMING=1                # 1 = stream TTS sentence-by-sentence (lower latency)
LLM_TOOLS=1                    # 1 = expose robot_tools to Ollama tool-call loop
LLM_TOOL_MAX_ITERS=3           # cap on tool_call → result → LLM round-trips per turn

# Long-term memory (Mem0 + embedded Qdrant + local bge-m3)
ROBOT_MEMORY=1                 # 1 = enable Mem0 fact extraction + rolling summary
MEM0_USER_ID=default           # partitions Qdrant by user for multi-person setups
MEM0_LLM_MODEL=qwen3.6:35b-a3b # LLM Mem0 calls for fact distillation
MEM0_EMBED_MODEL=bge-m3        # embedder served by Ollama

# LiteLLM proxy (multi-provider router, optional)
# LITELLM_BASE=http://localhost:4000
# LITELLM_KEY=
# LITELLM_MODEL=chat            # chat | vision | reason

# Anthropic direct (optional)
# ANTHROPIC_API_KEY=

# ── Vision (VLM) — periodic scene description for LLM prompt ──────────
VISION_URL=http://localhost:11434      # usually same Ollama
VISION_MODEL=qwen3.6:35b-a3b           # unified VL: same MoE serves dialog and vision
VISION_INTERVAL=10                      # seconds between frame captures

# ── STT (Whisper) ─────────────────────────────────────────────────────
WHISPER_URL=http://localhost:8881

# ── TTS ───────────────────────────────────────────────────────────────
# Engine: edge | kokoro
# - edge   = Microsoft Azure cloud (needs internet). Voice: en-US-AnaNeural (cute).
# - kokoro = Local GPU (kokoro-onnx). Needs kokoro_server.py running.
TTS_ENGINE=edge
KOKORO_URL=http://localhost:8880
KOKORO_VOICE=af_heart                   # af_heart / af_nicole / af_sky / af_bella ...

# TTS audio shaping
TTS_PEAK=0.95                           # peak-normalize each utterance to this level
TTS_GAIN=1.0                            # multiplied after normalization; >1 will clip

# TTS cache
TTS_CACHE_DIR=                           # default: <repo>/tts_cache
TTS_CACHE_MAX_MB=50                     # LRU eviction threshold

# ── GStreamer (WebRTC) ────────────────────────────────────────────────
# Path to Pollen's Rust plugins (gst-plugins-rs) if not in system path.
# GST_PLUGIN_PATH=/opt/gst-plugins-rs/lib/x86_64-linux-gnu
