# Default: treat as text, auto-convert line endings on checkout
* text=auto eol=lf

# Explicit text files (force LF)
*.py        text eol=lf
*.sh        text eol=lf
*.md        text eol=lf
*.toml      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.json      text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
*.service   text eol=lf
*.example   text eol=lf
Dockerfile  text eol=lf
Makefile    text eol=lf

# Binary files
*.onnx      binary
*.bin       binary
*.task      binary
*.wav       binary
*.mp3       binary
*.png       binary
*.jpg       binary
*.pt        binary
*.gguf      binary
*.safetensors binary
